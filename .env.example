# ============================================
# Xinki Portfolio — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================

# MySQL root 密码（修改为强密码，首次部署后勿改）
MYSQL_ROOT_PASSWORD=Xinki@2026

# Redis 密码（可选，默认为空即无密码）
# 若设置密码，生产环境建议修改
REDIS_PASSWORD=

# 阿里百炼 API Key（从 https://bailian.console.aliyun.com/ 获取）
BAILIAN_API_KEY=sk-your-key-here

# JWT 签名密钥（修改为随机字符串，至少 32 位）
# 生成命令：openssl rand -base64 32
JWT_SECRET=change-me-to-random-string

# 阿里云 OSS 凭据（从 RAM 访问控制获取）
OSS_ACCESS_KEY_ID=your-access-key-id
OSS_ACCESS_KEY_SECRET=your-access-key-secret
OSS_BUCKET_NAME=sky-17371
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com

# 域名（用于 SSL 证书申请，将 www.xinki.xyz 替换为你的域名）
DOMAIN=www.xinki.xyz